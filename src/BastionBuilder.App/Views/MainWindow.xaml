<Window x:Class="BastionBuilder.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:domain="clr-namespace:BastionBuilder.Domain.Enums;assembly=BastionBuilder.Domain"
        mc:Ignorable="d"
        Title="BastionBuilder"
        Height="700" Width="1100"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <ObjectDataProvider x:Key="EdgeKindValues"
                            MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="domain:EdgeKind"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- toolbar -->
            <RowDefinition Height="*"/>      <!-- main content -->
            <RowDefinition Height="Auto"/>   <!-- status bar -->
        </Grid.RowDefinitions>

        <!-- ── Toolbar ──────────────────────────────────────────────────── -->
        <ToolBar Grid.Row="0" Background="#2C2C54" Foreground="White">
            <Button Content="New Bastion"    Command="{Binding NewBastionCommand}"    Margin="2"/>
            <Button Content="Save"           Command="{Binding SaveCommand}"          Margin="2"/>
            <Separator/>
            <Button Content="Add Room"       Command="{Binding AddNodeCommand}"       Margin="2"/>
            <Button Content="Remove Room"    Command="{Binding RemoveNodeCommand}"    Margin="2"/>
            <Separator/>
            <Button Content="Add Edge"       Command="{Binding AddEdgeCommand}"       Margin="2"/>
            <Button Content="Remove Edge"    Command="{Binding RemoveEdgeCommand}"    Margin="2"/>
            <Separator/>
            <Button Content="Export Public"  Command="{Binding ExportPublicCommand}"  Margin="2"/>
            <Button Content="Export DM"      Command="{Binding ExportDmCommand}"      Margin="2"/>
        </ToolBar>

        <!-- ── Main content ─────────────────────────────────────────────── -->
        <Grid Grid.Row="1" Margin="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>     <!-- left panel: node list -->
                <ColumnDefinition Width="5"/>       <!-- splitter -->
                <ColumnDefinition Width="*"/>       <!-- centre: details -->
                <ColumnDefinition Width="5"/>       <!-- splitter -->
                <ColumnDefinition Width="220"/>     <!-- right panel: edge list -->
            </Grid.ColumnDefinitions>

            <!-- Bastion header (name + description) spans all columns -->
            <Grid Grid.Column="0" Grid.ColumnSpan="5" Margin="0,0,0,6">
                <!-- positioned at top, stacked -->
            </Grid>

            <!-- ── Left: Rooms (Nodes) ──────────────────────────────────── -->
            <GroupBox Grid.Column="0" Header="Rooms" Margin="0,0,2,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Margin="0,0,0,4">
                        <TextBlock Text="Bastion Name" FontSize="11" Foreground="#AAAACC"/>
                        <TextBox Text="{Binding BastionName, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,2,0,4"/>
                    </StackPanel>
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Nodes}"
                             SelectedItem="{Binding SelectedNode}"
                             DisplayMemberPath="Name"/>
                </Grid>
            </GroupBox>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="#444466" ResizeBehavior="PreviousAndNext"/>

            <!-- ── Centre: Detail panel ──────────────────────────────────── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Node detail -->
                <GroupBox Grid.Row="0" Header="Room Detail" Margin="0,0,0,3">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel DataContext="{Binding SelectedNode}" Margin="4">
                            <TextBlock Text="Name" FontSize="11" Foreground="#AAAACC"/>
                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,6"/>

                            <TextBlock Text="Public Description" FontSize="11" Foreground="#AAAACC"/>
                            <TextBox Text="{Binding PublicDescription, UpdateSourceTrigger=PropertyChanged}"
                                     Height="50" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,2,0,6"/>

                            <TextBlock Text="DM Description" FontSize="11" Foreground="#AAAACC"/>
                            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                     Height="50" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,2,0,6"/>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                    <TextBlock Text="Discoverability DC (0–20)" FontSize="11" Foreground="#AAAACC"/>
                                    <TextBox Text="{Binding DiscoverabilityDC, UpdateSourceTrigger=PropertyChanged}" Margin="0,2"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,4,0">
                                    <TextBlock Text="Height (ft)" FontSize="11" Foreground="#AAAACC"/>
                                    <TextBox Text="{Binding HeightFeet, UpdateSourceTrigger=PropertyChanged}" Margin="0,2"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Floor Level" FontSize="11" Foreground="#AAAACC"/>
                                    <TextBox Text="{Binding FloorLevel, UpdateSourceTrigger=PropertyChanged}" Margin="0,2"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Features" FontSize="11" Foreground="#AAAACC"/>
                            <ListBox ItemsSource="{Binding Features}"
                                     DisplayMemberPath="Name"
                                     Height="80" Margin="0,2"/>
                        </StackPanel>
                    </ScrollViewer>
                </GroupBox>

                <!-- Edge detail -->
                <GroupBox Grid.Row="1" Header="Edge Detail" Margin="0,3,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel DataContext="{Binding SelectedEdge}" Margin="4">
                            <TextBlock Text="Name" FontSize="11" Foreground="#AAAACC"/>
                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,6"/>

                            <TextBlock Text="Public Description" FontSize="11" Foreground="#AAAACC"/>
                            <TextBox Text="{Binding PublicDescription, UpdateSourceTrigger=PropertyChanged}"
                                     Height="40" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,2,0,6"/>

                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                    <TextBlock Text="Kind" FontSize="11" Foreground="#AAAACC"/>
                                    <ComboBox SelectedItem="{Binding Kind}"
                                              ItemsSource="{Binding Source={StaticResource EdgeKindValues}}"
                                              Margin="0,2"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Discoverability DC" FontSize="11" Foreground="#AAAACC"/>
                                    <TextBox Text="{Binding DiscoverabilityDC, UpdateSourceTrigger=PropertyChanged}" Margin="0,2"/>
                                </StackPanel>
                            </Grid>

                            <!-- Security flags -->
                            <WrapPanel Margin="0,0,0,4">
                                <CheckBox Content="Secret"    IsChecked="{Binding IsSecret}"  Margin="0,0,10,0"/>
                                <CheckBox Content="Has Lock"  IsChecked="{Binding HasLock}"   Margin="0,0,10,0"/>
                                <CheckBox Content="Has Trap"  IsChecked="{Binding HasTrap}"   Margin="0,0,10,0"/>
                                <CheckBox Content="Has Alarm" IsChecked="{Binding HasAlarm}"  Margin="0,0,10,0"/>
                                <CheckBox Content="Passable"  IsChecked="{Binding IsPassable}"/>
                            </WrapPanel>

                            <!-- Lock detail -->
                            <StackPanel Visibility="{Binding HasLock, Converter={StaticResource BoolToVis}}"
                                        Margin="0,0,0,4">
                                <TextBlock Text="Lock DC" FontSize="11" Foreground="#AAAACC"/>
                                <TextBox Text="{Binding LockDC, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,4"/>
                                <TextBlock Text="Lock Description" FontSize="11" Foreground="#AAAACC"/>
                                <TextBox Text="{Binding LockDescription, UpdateSourceTrigger=PropertyChanged}" Margin="0,2"/>
                            </StackPanel>

                            <!-- Trap detail -->
                            <StackPanel Visibility="{Binding HasTrap, Converter={StaticResource BoolToVis}}"
                                        Margin="0,0,0,4">
                                <TextBlock Text="Trap Kind" FontSize="11" Foreground="#AAAACC"/>
                                <TextBox Text="{Binding TrapKind, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,4"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                        <TextBlock Text="Detect DC" FontSize="11" Foreground="#AAAACC"/>
                                        <TextBox Text="{Binding TrapDetectDC, UpdateSourceTrigger=PropertyChanged}" Margin="0,2"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Disarm DC" FontSize="11" Foreground="#AAAACC"/>
                                        <TextBox Text="{Binding TrapDisarmDC, UpdateSourceTrigger=PropertyChanged}" Margin="0,2"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <!-- Alarm detail -->
                            <StackPanel Visibility="{Binding HasAlarm, Converter={StaticResource BoolToVis}}"
                                        Margin="0,0,0,4">
                                <TextBlock Text="Alarm Threshold" FontSize="11" Foreground="#AAAACC"/>
                                <TextBox Text="{Binding AlarmThreshold, UpdateSourceTrigger=PropertyChanged}" Margin="0,2"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </GroupBox>
            </Grid>

            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch"
                          Background="#444466" ResizeBehavior="PreviousAndNext"/>

            <!-- ── Right: Edges ──────────────────────────────────────────── -->
            <GroupBox Grid.Column="4" Header="Edges" Margin="2,0,0,0">
                <ListBox ItemsSource="{Binding Edges}"
                         SelectedItem="{Binding SelectedEdge}"
                         DisplayMemberPath="Name"/>
            </GroupBox>
        </Grid>

        <!-- ── Status bar ────────────────────────────────────────────────── -->
        <StatusBar Grid.Row="2" Background="#1A1A2E">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" Foreground="#AAAACC" Padding="4,2"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <ProgressBar Width="100" Height="12"
                             IsIndeterminate="{Binding IsBusy}"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
